{
  "$schema": "./tsconfig.schema.json",
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/*.bak*",
    "App_*.tsx",
    "App.tsx.*",
    "App.tsx.clean",
    "App.mobile.tsx",
    "ChatView.mobile.tsx",
    "novel-weaver-mobile",
    "novel-weaver-app"
  ],
  "references": [
    { "path": "./tsconfig.mobile.json" }
  ]
}